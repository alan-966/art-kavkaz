# Wagtail API (server-side base URL used at build/request time)
WAGTAIL_API_URL=http://localhost:8000/api/v2
WAGTAIL_BASE_URL=http://localhost:8000

# Must match NEXT_REVALIDATE_SECRET in backend/.env
REVALIDATE_SECRET=dev-secret-change-me

# Used for canonical URLs, sitemap, Open Graph — replace once a domain is registered
NEXT_PUBLIC_SITE_URL=http://localhost:3000
