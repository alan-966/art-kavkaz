# CORS: origins allowed to call the Wagtail API directly from the browser
CORS_ALLOWED_ORIGINS=http://localhost:3000

# On-demand revalidation webhook called from core/signals.py on page publish/unpublish.
# NEXT_REVALIDATE_SECRET must match REVALIDATE_SECRET in frontend/.env.local
NEXT_REVALIDATE_URL=http://localhost:3000/api/revalidate
NEXT_REVALIDATE_SECRET=dev-secret-change-me
